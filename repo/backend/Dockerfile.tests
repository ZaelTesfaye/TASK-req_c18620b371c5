FROM php:8.2-cli

RUN apt-get update && apt-get install -y \
    libzip-dev \
    zip \
    unzip \
    libpng-dev \
    libonig-dev \
    libxml2-dev \
    libcurl4-openssl-dev \
    && docker-php-ext-install pdo_mysql mbstring zip bcmath xml curl \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /app

COPY composer.json composer.lock* ./
RUN composer install --no-interaction 2>/dev/null || composer install --no-interaction

COPY . .

# Same .env bootstrap as the runtime image so PHPUnit picks up the
# committed dev defaults without compose duplicating them. compose's
# `env_file:` directive then layers the same values into the running
# container; the on-disk .env is the fallback when env vars are absent.
#
# Strip `#` comments via sed - PHP's parse_ini_file (used by
# \think\Env::load and indirectly by PHPUnit's bootstrap) only
# treats `;` as a comment marker, NOT `#`. Without this, every test
# that exercises App::initialize() (currently LogRedactionIntegration
# and AuditImmutability) trips on the parens inside the `#` comments
# at the top of .env.example and PHPUnit reports the warning as an
# error. See backend/Dockerfile for the longer rationale.
RUN sed -e '/^[[:space:]]*#/d' -e '/^[[:space:]]*$/d' .env.example > .env

RUN mkdir -p storage/keys storage/logs runtime \
    && chmod -R 777 storage runtime

# Ensure the test runner is executable inside the image (Windows hosts
# often drop the exec bit during COPY).
RUN chmod +x scripts/run-phpunit.sh

# Delegate to a dedicated script so the CMD stays simple AND all relevant
# logs (PHP server, PHP error_log, storage/logs, runtime/**/log) are
# dumped after phpunit finishes. Any 500 will now have the actual
# exception attached to the compose output.
CMD ["bash", "scripts/run-phpunit.sh"]
