FROM php:8.2-cli

RUN apt-get update && apt-get install -y \
    libzip-dev \
    zip \
    unzip \
    libpng-dev \
    libonig-dev \
    libxml2-dev \
    libcurl4-openssl-dev \
    && docker-php-ext-install pdo_mysql mbstring zip bcmath xml curl \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /app

COPY composer.json composer.lock* ./
RUN composer install --no-interaction 2>/dev/null || composer install --no-interaction

COPY . .

RUN mkdir -p storage/keys storage/logs runtime \
    && chmod -R 777 storage runtime

# Start PHP built-in server in background, then run PHPUnit
CMD bash -c "\
    php -S 0.0.0.0:8000 -t public/ > /dev/null 2>&1 & \
    sleep 2 && \
    vendor/bin/phpunit --configuration phpunit.xml --testdox"
