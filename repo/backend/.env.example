# FieldOps backend - safe development defaults.
#
# This file is the canonical source of dev-mode configuration. It is
# committed deliberately so a fresh `docker compose up` succeeds with
# no manual provisioning. The Dockerfile copies this file to `.env`
# inside the image at build time, and docker-compose.yml loads the
# same file via `env_file:` so credentials never appear inline in YAML.
#
# Production deployments MUST override every credential / key value
# below through a real secret manager (Kubernetes Secret, Vault, SOPS,
# AWS Parameter Store, etc.) - never reuse these placeholders.

# --- Application -----------------------------------------------------------
APP_NAME=FieldOps Service Suite
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost:8000
API_PREFIX=/api/v1
ENABLE_TLS=false

# --- Database (consumed by the backend AND by the MySQL container) ---------
DB_HOST=mysql
DB_PORT=3306
DB_NAME=fieldops
DB_USER=fieldops_user
DB_PASSWORD=fieldops_pass

# Variables read by the official mysql:8.0 image on first init. Kept in
# sync with DB_* above so the backend and the database agree on the
# same user/password/database name.
MYSQL_ROOT_PASSWORD=fieldops_root_pass
MYSQL_DATABASE=fieldops
MYSQL_USER=fieldops_user
MYSQL_PASSWORD=fieldops_pass

# --- Auth / session --------------------------------------------------------
SESSION_TTL_MINUTES=480
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
PASSWORD_MIN_LENGTH=12

# --- Operational tunables --------------------------------------------------
DEFAULT_TAX_RATE=0.08
AUDIT_LOG_RETENTION_YEARS=7
DISCREPANCY_THRESHOLD_USD=1.00
DEFAULT_TIME_BUCKET_MINUTES=1
LATE_ARRIVAL_TOLERANCE_MINUTES=5
CSV_EXPORT_ENCODING=UTF-8
ENABLE_EXPERIMENTS=true

# --- Encryption ------------------------------------------------------------
# !!! DEVELOPMENT PLACEHOLDER - NEVER USE IN PRODUCTION !!!
# The `base64:` form is used here (instead of the versioned JSON map) so
# the value survives shell / .env / INI parsers without quote escaping.
# EncryptionService accepts both shapes; see resolveEnvKey() for details.
# Before any non-local deployment: generate a fresh 32-byte random key
# and inject it through a secret manager, OR mount a real key file via
# ENCRYPTION_KEYS_FILE_PATH and remove ENCRYPTION_KEY below.
ENCRYPTION_ACTIVE_KEY_VERSION=1
ENCRYPTION_KEYS_FILE_PATH=/app/storage/keys/encryption.key
ENCRYPTION_KEY=base64:ZGV2LW9ubHktZW5jcnlwdGlvbi1rZXktMzItYnl0ZXNfXw==
