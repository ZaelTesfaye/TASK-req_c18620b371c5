{
    "name": "fieldops/backend",
    "description": "FieldOps Service & Environmental Analytics Suite - Backend API",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "topthink/framework": "^6.1",
        "topthink/think-orm": "^2.0",
        "topthink/think-multi-app": "^1.0",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/",
            "config\\": "config/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml --testdox",
        "test-unit": "phpunit --configuration phpunit.xml --testsuite unit --testdox",
        "test-api": "phpunit --configuration phpunit.xml --testsuite api --testdox"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    }
}
