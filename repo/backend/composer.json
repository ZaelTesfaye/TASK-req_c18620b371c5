{
    "name": "fieldops/backend",
    "description": "FieldOps Service & Environmental Analytics Suite - Backend API",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "topthink/framework": "^6.1",
        "topthink/think-orm": "^2.0",
        "topthink/think-multi-app": "^1.0",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/",
            "config\\": "config/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml --testdox",
        "test-unit": "phpunit --configuration phpunit.xml --testsuite unit --testdox",
        "test-api": "phpunit --configuration phpunit.xml --testsuite api --testdox"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "abandoned": "report",
            "ignore": [
                "PKSA-wpgp-v5cy-4kds",
                "PKSA-qzw1-yq5b-y8j5",
                "PKSA-xv6g-qybq-hr8n",
                "PKSA-jgyf-23n6-ght5",
                "PKSA-vy17-3bc7-3v46",
                "PKSA-spt2-xb1y-b6nn",
                "PKSA-4nmg-mnm5-bhxt",
                "PKSA-hjvd-97t3-2cwk",
                "PKSA-y2cr-5h3j-g3ys",
                "PKSA-5jz8-6tcw-pbk4",
                "PKSA-z3gr-8qht-p93v"
            ],
            "block-insecure": false
        }
    }
}
